{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(WhatsApp|facebook|Twitterbot|LinkedInBot|Discordbot|TelegramBot|google|bot|crawler|spider|slack|vkShare|SkypeShell|Applebot).*"
        }
      ],
      "destination": "/api/seo"
    },
    {
      "source": "/propriedade/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(WhatsApp|facebook|Twitterbot|LinkedInBot|Discordbot|TelegramBot|google|bot|crawler|spider|slack|vkShare|SkypeShell|Applebot).*"
        }
      ],
      "destination": "/api/seo?slug=:slug"
    },
    {
      "source": "/((?!assets/|favicon.ico|.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.svg|.*\\.webp|.*\\.mp4|.*\\.pdf|api/).*)",
      "destination": "/index.html"
    }
  ]
}
